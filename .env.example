# ============================================================
# genai_capability_bench - provider configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ============================================================

# ------------------------------------------------------------
# Common model roles used by this repo
# ------------------------------------------------------------
# OPENAI_GENERATION_MODEL is the model being evaluated.
# OPENAI_JUDGE_MODEL is optional and used by LLM-as-judge metrics when enabled.
# OPENAI_EMBEDDING_MODEL is optional and used by embedding-based metrics when enabled.
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_JUDGE_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Semantic similarity defaults to local TF-IDF for reproducibility.
# In notebooks, set USE_API_EMBEDDINGS=True to use OPENAI_EMBEDDING_MODEL
# for embedding cosine similarity instead.

# Some reasoning/GPT-5-style deployments do not support temperature or token
# limit parameters on chat completions. Use "omit" to skip sending them.
OPENAI_TEMPERATURE=omit
OPENAI_MAX_TOKENS=omit
OPENAI_TOKEN_PARAMETER=

# For providers/models that support explicit generation controls, use:
# OPENAI_TEMPERATURE=0.0
# OPENAI_MAX_TOKENS=1000
# OPENAI_TOKEN_PARAMETER=max_tokens

# Optional evaluation defaults
EVAL_PASS_THRESHOLD=0.7
QUICK_TEST_N=10

# ------------------------------------------------------------
# OPTION A: Azure OpenAI or Azure API Management gateway
# ------------------------------------------------------------
# Set OPENAI_API_VERSION to activate AzureOpenAI client mode.
# OPENAI_BASE_URL should be your Azure endpoint or gateway endpoint.
OPENAI_API_KEY=your-azure-or-gateway-key
OPENAI_BASE_URL=https://your-resource-or-gateway.example.com
OPENAI_API_VERSION=2025-04-01-preview

# Optional custom API gateway header, for example Azure API Management.
# Leave blank for standard Azure OpenAI endpoints.
OPENAI_APIM_HEADER_NAME=
OPENAI_APIM_SUBSCRIPTION_KEY=

# Example Azure deployment names:
# OPENAI_GENERATION_MODEL=your-generation-deployment-name
# OPENAI_JUDGE_MODEL=your-judge-deployment-name
# For models that reject temperature/max token controls:
# OPENAI_TEMPERATURE=omit
# OPENAI_MAX_TOKENS=omit
# OPENAI_TOKEN_PARAMETER=

# ------------------------------------------------------------
# OPTION B: OpenAI direct
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_VERSION=
# OPENAI_GENERATION_MODEL=gpt-4o
# OPENAI_JUDGE_MODEL=gpt-4o

# ------------------------------------------------------------
# OPTION C: Ollama local
# ------------------------------------------------------------
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_VERSION=
# OPENAI_GENERATION_MODEL=llama3
# OPENAI_JUDGE_MODEL=llama3

# ------------------------------------------------------------
# OPTION D: Groq
# ------------------------------------------------------------
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_VERSION=
# OPENAI_GENERATION_MODEL=llama-3.1-70b-versatile
# OPENAI_JUDGE_MODEL=llama-3.1-70b-versatile

# ------------------------------------------------------------
# OPTION E: Together AI
# ------------------------------------------------------------
# OPENAI_API_KEY=your-together-key
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_API_VERSION=
# OPENAI_GENERATION_MODEL=meta-llama/Llama-3-70b-chat-hf
# OPENAI_JUDGE_MODEL=meta-llama/Llama-3-70b-chat-hf

# ------------------------------------------------------------
# OPTION F: LM Studio local
# ------------------------------------------------------------
# OPENAI_API_KEY=lm-studio
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_VERSION=
# OPENAI_GENERATION_MODEL=your-loaded-model-name
# OPENAI_JUDGE_MODEL=your-loaded-model-name
