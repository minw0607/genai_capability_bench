# OpenAI-compatible provider settings.
# Leave OPENAI_API_VERSION blank for direct OpenAI-compatible endpoints.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_VERSION=

# Optional custom API gateway header, for example Azure APIM.
OPENAI_APIM_HEADER_NAME=
OPENAI_APIM_SUBSCRIPTION_KEY=

OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_JUDGE_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

